<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Deltaria SMP - Official Minecraft Server</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <nav>
        <div class="nav-logo">DELTARIA SMP</div>
        <ul class="nav-links">
            <li><a href="#home">Home</a></li>
            <li><a href="#fitur">Fitur</a></li>
            <li><a href="https://github.com/deltaria-smp" target="_blank">GitHub</a></li>
        </ul>
    </nav>

    <section class="hero" id="home">
        <h1>Satu Komunitas, Tanpa Batas</h1>
        <p>Selamat datang di Deltaria SMP. Survival Multiplayer Server berbasis Cross-Play Java & Bedrock dengan optimasi performa tinggi, sistem ekonomi adil, dan ekosistem mandiri.</p>
        
        <div class="ip-container">
            
            <div class="ip-widget java-theme" onclick="copyJavaIp()" title="Klik untuk menyalin IP Java">
                <div class="server-icon">☕</div> <div class="ip-box">
                    <div class="ip-label">Minecraft Java Edition</div>
                    <div class="ip-address" id="javaIp">play.lunarmine.my.id:1111</div>
                </div>
                <button class="btn-copy" id="javaBtn">SALIN IP</button>
            </div>

            <div class="ip-widget bedrock-theme" onclick="copyBedrockIp()" title="Klik untuk menyalin IP Bedrock">
                <div class="server-icon">🧱</div> <div class="ip-box">
                    <div class="ip-label">Minecraft Bedrock (HP/Konsol)</div>
                    <div class="ip-address">
                        <span id="bedrockIp">play.lunarmine.my.id</span> 
                        <span class="port-label">Port: <strong id="bedrockPort">1111</strong></span>
                    </div>
                </div>
                <button class="btn-copy" id="bedrockBtn">SALIN IP</button>
            </div>

        </div>
    </section>

    <script>
        // Fungsi Salin IP Java
        function copyJavaIp() {
            const ipText = document.getElementById('javaIp').innerText;
            const btn = document.getElementById('javaBtn');
            executeCopy(ipText, btn);
        }

        // Fungsi Salin IP Bedrock (Hanya menyalin Domain/IP tanpa tulisan kata "Port")
        function copyBedrockIp() {
            const ipText = document.getElementById('bedrockIp').innerText;
            const btn = document.getElementById('bedrockBtn');
            executeCopy(ipText, btn);
        }

        // Core fungsi eksekusi clipboard
        function executeCopy(text, buttonElement) {
            navigator.clipboard.writeText(text).then(() => {
                buttonElement.innerText = "TERSALIN!";
                buttonElement.style.backgroundColor = "#10b981";
                buttonElement.style.color = "#fff";
                
                setTimeout(() => {
                    buttonElement.innerText = "SALIN IP";
                    buttonElement.style.backgroundColor = "#38bdf8";
                    buttonElement.style.color = "#0a0c14";
                }, 2000);
            }).catch(err => {
                console.error('Gagal menyalin text: ', err);
            });
        }
    </script>

    <div class="ip-flex-row">
            
            <div class="ip-widget java-theme" onclick="copyJavaIp()" title="Klik untuk menyalin IP Java">
                <div class="server-icon">☕</div>
                <div class="ip-box">
                    <div class="ip-label">Minecraft Java Edition</div>
                    <div class="ip-address" id="javaIp">play.lunarmine.my.id:1111</div>
                </div>
                <button class="btn-copy" id="javaBtn">SALIN IP</button>
            </div>

            <div class="ip-widget bedrock-theme" onclick="copyBedrockIp()" title="Klik untuk menyalin IP Bedrock">
                <div class="server-icon">🧱</div>
                <div class="ip-box">
                    <div class="ip-label">Minecraft Bedrock</div>
                    <div class="ip-address">
                        <span id="bedrockIp">play.lunarmine.my.id</span> 
                        <span class="port-label">Port: <strong id="bedrockPort">1111</strong></span>
                    </div>
                </div>
                <button class="btn-copy" id="bedrockBtn">SALIN IP</button>
            </div>

        </div>

    <footer>
        <p>&copy; 2026 Deltaria SMP Community. Website dibangun secara native melalui repositori organisasi.</p>
        <p style="margin-top: 5px; font-size: 11px; color: #334155;">Tidak berafiliasi dengan Mojang Synergies AB.</p>
    </footer>

    <script>
        function copyIpServer() {
            const ipText = document.getElementById('serverIp').innerText;
            const btn = document.getElementById('copyBtn');
            
            navigator.clipboard.writeText(ipText).then(() => {
                btn.innerText = "TERSALIN!";
                btn.style.backgroundColor = "#10b981";
                
                setTimeout(() => {
                    btn.innerText = "SALIN IP";
                    btn.style.backgroundColor = "#38bdf8";
                }, 2000);
            }).catch(err => {
                console.error('Gagal menyalin IP: ', err);
            });
        }
    </script>
</body>
</html>
